---
// PÚLSAR - NEO ESPORTS (VERSIÓN MORADO CYBERPUNK EXTENDIDA)
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Púlsar - Descubrimiento Indie</title>
    <style>
        :root {
            --fondo: #0D0D0D; 
            --texto: #FFFFFF;
            --texto-dim: #888888;
            --acento: #B026FF; /* Morado Neón */
            --tarjeta: #1A1A1A; 
            --borde: #333333;
        }
        
        body { margin: 0; font-family: 'Arial Black', Impact, sans-serif; background: var(--fondo); color: var(--texto); text-transform: uppercase; overflow-x: hidden; }
        
        /* SCROLLBAR PERSONALIZADO */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--fondo); }
        ::-webkit-scrollbar-thumb { background: var(--tarjeta); border: 1px solid var(--acento); }
        ::-webkit-scrollbar-thumb:hover { background: var(--acento); }

        /* NAVEGACIÓN */
        header { position: sticky; top: 0; background: rgba(13, 13, 13, 0.9); padding: 20px 40px; z-index: 100; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--acento); backdrop-filter: blur(10px); }
        .logo { font-size: 1.8rem; text-shadow: 0 0 15px rgba(176, 38, 255, 0.8); margin: 0; color: var(--texto); letter-spacing: 2px; }
        .search { background: transparent; border: 2px solid var(--borde); padding: 12px 20px; color: var(--texto); width: 300px; text-transform: uppercase; font-weight: bold; transition: all 0.3s; }
        .search:focus { border-color: var(--acento); outline: none; box-shadow: 0 0 15px rgba(176, 38, 255, 0.4); }
        
        /* HERO SECTION */
        .hero { height: 80vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 60px; background: linear-gradient(to top, var(--fondo) 10%, transparent), url('https://picsum.photos/1920/1080?random=100') center/cover; border-bottom: 5px solid var(--tarjeta); }
        .hero-tag { display: inline-block; background: var(--acento); color: var(--texto); padding: 5px 10px; font-size: 1rem; margin-bottom: 15px; width: max-content; box-shadow: 0 0 15px rgba(176, 38, 255, 0.5); }
        .hero h1 { font-size: 5rem; margin: 0 0 20px 0; color: white; text-shadow: 4px 4px 0px #000; letter-spacing: -2px; line-height: 1; }
        .btn-wishlist { background: var(--acento); color: var(--texto); border: none; padding: 15px 40px; font-weight: bold; cursor: pointer; font-size: 1.2rem; transition: all 0.2s; width: max-content; box-shadow: 0 0 20px rgba(176, 38, 255, 0.4); }
        .btn-wishlist:hover { background: var(--texto); color: var(--fondo); box-shadow: 0 0 30px rgba(255, 255, 255, 0.6); transform: scale(1.05); }

        /* TÍTULOS DE SECCIÓN */
        .section-title { padding: 40px 40px 10px 40px; font-size: 2rem; color: var(--texto); display: flex; align-items: center; gap: 15px; margin: 0; }
        .section-title::before { content: ''; display: block; width: 20px; height: 20px; background: var(--acento); box-shadow: 0 0 10px var(--acento); }

        /* GRILLAS Y TARJETAS */
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; padding: 20px 40px 60px 40px; }
        .card { background: var(--tarjeta); overflow: hidden; border: 1px solid var(--borde); border-left: 5px solid transparent; transition: all 0.3s; display: flex; flex-direction: column; }
        .card:hover { border-left-color: var(--acento); transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.8), 0 0 15px rgba(176, 38, 255, 0.2); border-color: #444; }
        .card img { width: 100%; height: 180px; object-fit: cover; filter: grayscale(60%) contrast(120%); transition: filter 0.4s; }
        .card:hover img { filter: grayscale(0%) contrast(100%); }
        .card-content { padding: 20px; display: flex; flex-direction: column; flex-grow: 1; justify-content: space-between; }
        .card h3 { margin: 0 0 10px 0; font-size: 1.3rem; letter-spacing: 1px; }
        .card .tags { font-size: 0.8rem; color: var(--texto-dim); margin-bottom: 15px; }
        .card .precio { color: var(--acento); font-family: monospace; font-size: 1.5rem; text-shadow: 0 0 8px rgba(176, 38, 255, 0.4); margin: 0; }

        /* SECCIÓN DEVLOGS (LA NEBULOSA) */
        .devlogs-container { background: #111; padding: 40px; border-top: 1px dashed var(--borde); border-bottom: 1px dashed var(--borde); }
        .devlog-card { background: var(--fondo); border: 1px solid var(--acento); padding: 25px; margin-bottom: 20px; box-shadow: 4px 4px 0px var(--acento); }
        .devlog-card h4 { margin: 0 0 10px 0; font-size: 1.5rem; color: var(--acento); }
        .devlog-card p { font-family: sans-serif; text-transform: none; color: #CCC; line-height: 1.6; font-size: 1.1rem; margin: 0; }
        .devlog-date { font-family: monospace; color: var(--texto-dim); font-size: 0.9rem; margin-bottom: 15px; display: block; }

        /* FOOTER */
        footer { background: var(--tarjeta); padding: 60px 40px; text-align: center; border-top: 5px solid var(--acento); }
        footer h2 { font-size: 3rem; margin: 0 0 20px 0; color: var(--borde); }
        footer p { font-family: sans-serif; text-transform: none; color: var(--texto-dim); }

        /* ANIMACIONES SCROLL */
        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.6s cubic-bezier(0.1, 0.8, 0.2, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body>

    <header>
        <h2 class="logo">[ PÚLSAR ]</h2>
        <input type="text" class="search" placeholder="ESCANEAR CATÁLOGO...">
    </header>
    
    <section class="hero">
        <div class="hero-tag">🔥 ANOMALÍA DETECTADA - #1 WISHLIST</div>
        <h1>SOMBRAS DEL<br>VACÍO</h1>
        <button class="btn-wishlist">INICIAR EXTRACCIÓN // 19.99 CRD</button>
    </section>

    <h2 class="section-title reveal">ESCÁNER GENERAL (CATÁLOGO EN VIVO)</h2>
    <section class="grid" id="catalogo-grid">
        <div class="card reveal"><img src="https://picsum.photos/400/300?random=201"><div class="card-content"><div><h3>Neon Drifter</h3><div class="tags">ACCION // CYBERPUNK</div></div><p class="precio">14.99 CRD</p></div></div>
        <div class="card reveal" style="transition-delay: 0.1s;"><img src="https://picsum.photos/400/300?random=202"><div class="card-content"><div><h3>Starseed</h3><div class="tags">ESTRATEGIA // ESPACIAL</div></div><p class="precio">9.99 CRD</p></div></div>
        <div class="card reveal" style="transition-delay: 0.2s;"><img src="https://picsum.photos/400/300?random=203"><div class="card-content"><div><h3>Pixel Farm</h3><div class="tags">SIMULADOR // CASUAL</div></div><p class="precio">19.99 CRD</p></div></div>
        <div class="card reveal" style="transition-delay: 0.3s;"><img src="https://picsum.photos/400/300?random=204"><div class="card-content"><div><h3>Redemption</h3><div class="tags">HORROR // SURVIVAL</div></div><p class="precio">12.50 CRD</p></div></div>
    </section>

    <h2 class="section-title reveal" style="color: var(--acento);">EL PULSO: JOYAS OCULTAS (EL NÚCLEO + LA NEBULOSA)</h2>
    <p class="reveal" style="padding: 0 40px; font-family: sans-serif; text-transform: none; color: var(--texto-dim);">Nuestra Inteligencia Artificial cruza PostgreSQL y MongoDB en tiempo real a través de El Puente para encontrar estos títulos.</p>
    <section class="grid" id="joyas-grid">
        <div class="card reveal"><div class="card-content"><h3>CARGANDO DATOS REALES DE EL PULSO...</h3></div></div>
    </section>

    <div class="devlogs-container">
        <h2 class="section-title reveal" style="padding: 0 0 20px 0; color: white;">TRANSMISIONES DE DESARROLLADORES (LA NEBULOSA)</h2>
        <div id="devlogs-list">
            <div class="devlog-card reveal">
                <span class="devlog-date">SISTEMA: NEON DRIFTER // FECHA ESTELAR: 2026.07.13</span>
                <h4>REDISEÑO DEL SISTEMA DE DERRAPES</h4>
                <p>Hemos pasado las últimas 40 horas ajustando las físicas de los vehículos. Ahora, al realizar un derrape perfecto en las esquinas de neón, el multiplicador de puntos se acumula un 15% más rápido.</p>
            </div>
        </div>
    </div>

    <footer class="reveal">
        <h2>[ PÚLSAR_ ]</h2>
        <p>CONECTANDO EL UNIVERSO INDIE DESDE 2026</p>
        <div style="margin-top: 20px; font-family: monospace; color: var(--acento);" id="api-status">
            <span>EL PUENTE: CONECTANDO...</span> // <span>IA ACTIVA</span> // <span>CONEXIÓN SEGURA</span>
        </div>
    </footer>

    <script>
        const API_BASE = "http://127.0.0.1:8000/api/v1";

        // Sistema Intersection Observer para animaciones scroll
        function initObserver() {
            const reveals = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.15 });
            
            reveals.forEach(reveal => observer.observe(reveal));
        }

        // Carga de datos reales desde El Puente (FastAPI)
        async function cargarDatosPuente() {
            const statusEl = document.getElementById('api-status');
            const joyasGrid = document.getElementById('joyas-grid');
            const devlogsList = document.getElementById('devlogs-list');

            try {
                // Check de Salud
                const healthRes = await fetch(`${API_BASE}/health`);
                if (healthRes.ok) {
                    statusEl.innerHTML = `<span style="color: #00FF66;">EL PUENTE: ONLINE (POSTGRES OK | MONGO OK)</span> // <span>IA ACTIVA</span>`;
                }

                // Cargar Catálogo Cruzado
                const radarRes = await fetch(`${API_BASE}/radar`);
                if (radarRes.ok) {
                    const data = await radarRes.json();
                    if (data.juegos && data.juegos.length > 0) {
                        joyasGrid.innerHTML = '';
                        data.juegos.forEach((juego, index) => {
                            const tagsHtml = juego.etiquetas.join(' // ');
                            const cardHtml = `
                                <div class="card reveal active" style="transition-delay: ${index * 0.1}s; border-color: var(--acento);">
                                    <img src="https://picsum.photos/400/300?random=${200 + index}">
                                    <div class="card-content">
                                        <div>
                                            <h3 style="color: var(--acento);">${juego.titulo}</h3>
                                            <div class="tags">${tagsHtml.toUpperCase()} // ${juego.plataforma}</div>
                                            <p style="font-family: sans-serif; text-transform: none; color: #BBB; font-size: 0.9rem; margin-top: 10px;">${juego.descripcion}</p>
                                        </div>
                                        <p class="precio">${juego.precio}</p>
                                    </div>
                                </div>
                            `;
                            joyasGrid.innerHTML += cardHtml;
                        });
                    }
                }

                // Cargar DevLogs desde La Nebulosa
                const devlogsRes = await fetch(`${API_BASE}/devlogs`);
                if (devlogsRes.ok) {
                    const devData = await devlogsRes.json();
                    if (devData.transmisiones && devData.transmisiones.length > 0) {
                        devlogsList.innerHTML = '';
                        devData.transmisiones.forEach((log) => {
                            const devlogHtml = `
                                <div class="devlog-card reveal active">
                                    <span class="devlog-date">SISTEMA: EL PULSO // FECHA ESTELAR: ${log.fecha}</span>
                                    <h4>${log.titulo.toUpperCase()}</h4>
                                    <p>${log.contenido}</p>
                                </div>
                            `;
                            devlogsList.innerHTML += devlogHtml;
                        });
                    }
                }

            } catch (err) {
                console.warn("API de El Puente fuera de línea o cargando datos locales fallback:", err);
                if (statusEl) {
                    statusEl.innerHTML = `<span style="color: #FF3366;">EL PUENTE: OFFLINE (MODO STANDALONE)</span> // <span>IA ACTIVA</span>`;
                }
            } finally {
                initObserver();
            }
        }

        // Ejecución inicial
        document.addEventListener('DOMContentLoaded', () => {
            cargarDatosPuente();
        });
    </script>
</body>
</html>